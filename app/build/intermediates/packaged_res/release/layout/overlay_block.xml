<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="20dp"
            android:background="@drawable/glass_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="32dp">

            <ImageView
                android:id="@+id/ivLockIcon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_kiddo_3d_icon" />

            <TextView
                android:id="@+id/tvBlockedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/overlay_security_badge"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBlockedMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:text="@string/overlay_blocked_msg"
                android:textColor="#B0FFFFFF"
                android:textSize="13sp" />

            <!-- AI Nudge Area -->
            <TextView
                android:id="@+id/tvNudgeMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_nudge_bg"
                android:gravity="center"
                android:padding="10dp"
                android:text="✨ הגיע הזמן לקצת קריאה או יצירה?"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="italic"
                android:visibility="visible" />

            <!-- PIN Indicators -->
            <LinearLayout
                android:id="@+id/pinIndicatorContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <View android:id="@+id/pinDot1" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
                <View android:id="@+id/pinDot2" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
                <View android:id="@+id/pinDot3" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
                <View android:id="@+id/pinDot4" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
            </LinearLayout>

            <!-- Numeric Keypad -->
            <GridLayout
                android:id="@+id/pinKeypad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:layout_marginBottom="12dp"
                android:visibility="gone">
                
                <Button style="@style/PinPadButton" android:text="1" android:id="@+id/btn1"/>
                <Button style="@style/PinPadButton" android:text="2" android:id="@+id/btn2"/>
                <Button style="@style/PinPadButton" android:text="3" android:id="@+id/btn3"/>
                
                <Button style="@style/PinPadButton" android:text="4" android:id="@+id/btn4"/>
                <Button style="@style/PinPadButton" android:text="5" android:id="@+id/btn5"/>
                <Button style="@style/PinPadButton" android:text="6" android:id="@+id/btn6"/>
                
                <Button style="@style/PinPadButton" android:text="7" android:id="@+id/btn7"/>
                <Button style="@style/PinPadButton" android:text="8" android:id="@+id/btn8"/>
                <Button style="@style/PinPadButton" android:text="9" android:id="@+id/btn9"/>
                
                <View android:layout_width="60dp" android:layout_height="60dp"/>
                <Button style="@style/PinPadButton" android:text="0" android:id="@+id/btn0"/>
                <ImageButton style="@style/PinPadButton" android:src="@drawable/ic_back" android:id="@+id/btnDelete" android:contentDescription="Delete" android:scaleType="centerInside" android:padding="16dp"/>
            </GridLayout>

            <TextView
                android:id="@+id/tvGoBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/overlay_go_back"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/tvParentUnlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="🔒 פתיחה להורים"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:padding="8dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>

