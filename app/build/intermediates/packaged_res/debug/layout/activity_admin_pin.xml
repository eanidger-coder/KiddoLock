<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_dark_gradient"
    android:padding="32dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/tvPinTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="קוד גישה להורים"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvPinSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="אנא הזן את קוד הגישה (PIN) כדי להמשיך"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />

            <!-- PIN Indicators -->
            <LinearLayout
                android:id="@+id/pinIndicatorContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <View android:id="@+id/pinDot1" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
                <View android:id="@+id/pinDot2" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
                <View android:id="@+id/pinDot3" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
                <View android:id="@+id/pinDot4" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty"/>
            </LinearLayout>

            <!-- Custom Keypad -->
            <GridLayout
                android:id="@+id/pinKeypad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:layout_marginBottom="16dp">
                
                <Button style="@style/PinPadButton" android:text="1" android:id="@+id/btn1"/>
                <Button style="@style/PinPadButton" android:text="2" android:id="@+id/btn2"/>
                <Button style="@style/PinPadButton" android:text="3" android:id="@+id/btn3"/>
                
                <Button style="@style/PinPadButton" android:text="4" android:id="@+id/btn4"/>
                <Button style="@style/PinPadButton" android:text="5" android:id="@+id/btn5"/>
                <Button style="@style/PinPadButton" android:text="6" android:id="@+id/btn6"/>
                
                <Button style="@style/PinPadButton" android:text="7" android:id="@+id/btn7"/>
                <Button style="@style/PinPadButton" android:text="8" android:id="@+id/btn8"/>
                <Button style="@style/PinPadButton" android:text="9" android:id="@+id/btn9"/>
                
                <View android:layout_width="60dp" android:layout_height="60dp"/>
                <Button style="@style/PinPadButton" android:text="0" android:id="@+id/btn0"/>
                <ImageButton style="@style/PinPadButton" android:src="@drawable/ic_back" android:id="@+id/btnDelete" android:contentDescription="Delete" android:scaleType="centerInside" android:padding="16dp"/>
            </GridLayout>

            <TextView
                android:id="@+id/tvLockoutTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/error_red"
                android:visibility="gone"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvForgotPin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שכחת סיסמה?"
                android:textColor="@color/accent_blue"
                android:layout_marginTop="16dp"
                android:padding="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
