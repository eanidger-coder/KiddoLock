<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- App Icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_kiddo_3d_icon"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="KiddoLock" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="הגדרה ראשונית"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:hyphenationFrequency="none"
            android:breakStrategy="simple" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="לחץ על כל שלב לפי הסדר כדי להפעיל"
            android:textColor="@color/cyan_accent"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:hyphenationFrequency="none"
            android:breakStrategy="simple" />

        <!-- ══════════════ Step 1: Notifications ══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardNotifications"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Step number -->
            <TextView
                android:id="@+id/tvStep1Num"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/setup_icon_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvStep1Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="אשר התראות"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep1Num"
                app:layout_constraintEnd_toStartOf="@id/tvNotifAction"
                app:layout_constraintHorizontal_weight="7"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />

            <!-- Action hint -->
            <TextView
                android:id="@+id/tvNotifAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="לחץ להפעלה ←"
                android:textColor="@color/cyan_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep1Title"
                app:layout_constraintEnd_toStartOf="@id/imgNotificationStatus"
                app:layout_constraintHorizontal_weight="3" />

            <!-- Status icon -->
            <ImageView
                android:id="@+id/imgNotificationStatus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_status_pending"
                android:contentDescription="סטטוס"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHelpNotifications" />

            <ImageButton
                android:id="@+id/btnHelpNotifications"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_help"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@color/cyan_accent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Help Guide 1 -->
        <LinearLayout
            android:id="@+id/layoutHelpNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="-10dp"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@drawable/glass_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="איך לאשר התראות?"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <ImageView
                android:id="@+id/imgGuideNotifications"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ══════════════ Step 2: Overlay ══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardOverlay"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvStep2Num"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/setup_icon_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvStep2Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="אשר תצוגה מעל אפליקציות"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep2Num"
                app:layout_constraintEnd_toStartOf="@id/tvOverlayAction"
                app:layout_constraintHorizontal_weight="7"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />

            <TextView
                android:id="@+id/tvOverlayAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="לחץ להפעלה ←"
                android:textColor="@color/cyan_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep2Title"
                app:layout_constraintEnd_toStartOf="@id/imgOverlayStatus"
                app:layout_constraintHorizontal_weight="3" />

            <ImageView
                android:id="@+id/imgOverlayStatus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_status_pending"
                android:contentDescription="סטטוס"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHelpOverlay" />

            <ImageButton
                android:id="@+id/btnHelpOverlay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_help"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@color/cyan_accent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Help Guide 2 -->
        <LinearLayout
            android:id="@+id/layoutHelpOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="-10dp"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@drawable/glass_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="איך לאשר תצוגה מעל אפליקציות?"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <ImageView
                android:id="@+id/imgGuideOverlay"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ══════════════ Step 3: Accessibility ══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardAccessibility"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvStep3Num"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/setup_icon_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvStep3Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="הפעל שירות נגישות"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep3Num"
                app:layout_constraintEnd_toStartOf="@id/tvAccessibilityAction"
                app:layout_constraintHorizontal_weight="7"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />

            <TextView
                android:id="@+id/tvAccessibilityAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="לחץ להפעלה ←"
                android:textColor="@color/cyan_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep3Title"
                app:layout_constraintEnd_toStartOf="@id/imgAccessibilityStatus"
                app:layout_constraintHorizontal_weight="3" />

            <ImageView
                android:id="@+id/imgAccessibilityStatus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_status_pending"
                android:contentDescription="סטטוס"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHelpAccessibility" />

            <ImageButton
                android:id="@+id/btnHelpAccessibility"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_help"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@color/cyan_accent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Help Guide 3 -->
        <LinearLayout
            android:id="@+id/layoutHelpAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="-10dp"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@drawable/glass_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="איך להפעיל חסימת אפליקציות?"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <ImageView
                android:id="@+id/imgGuideAccessibility"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ══════════════ Step 4: Device Admin ══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardDeviceAdmin"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvStep4Num"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="4"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/setup_icon_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvStep4Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="הפעל מנהל מכשיר"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep4Num"
                app:layout_constraintEnd_toStartOf="@id/tvAdminAction"
                app:layout_constraintHorizontal_weight="7"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />

            <TextView
                android:id="@+id/tvAdminAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="לחץ להפעלה ←"
                android:textColor="@color/cyan_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep4Title"
                app:layout_constraintEnd_toStartOf="@id/imgDeviceAdminStatus"
                app:layout_constraintHorizontal_weight="3" />

            <ImageView
                android:id="@+id/imgDeviceAdminStatus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_status_pending"
                android:contentDescription="סטטוס"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHelpAdmin" />

            <ImageButton
                android:id="@+id/btnHelpAdmin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_help"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@color/cyan_accent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Help Guide 4 -->
        <LinearLayout
            android:id="@+id/layoutHelpAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="-10dp"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@drawable/glass_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="איך להפעיל הגנת הסרה?"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <ImageView
                android:id="@+id/imgGuideAdmin"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ══════════════ Step 5: Usage Access ══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardUsageAccess"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvStep5Num"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/setup_icon_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvStep5Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="אשר גישה לנתוני שימוש"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep5Num"
                app:layout_constraintEnd_toStartOf="@id/tvUsageAction"
                app:layout_constraintHorizontal_weight="7"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />

            <TextView
                android:id="@+id/tvUsageAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="לחץ להפעלה ←"
                android:textColor="@color/cyan_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvStep5Title"
                app:layout_constraintEnd_toStartOf="@id/imgUsageStatus"
                app:layout_constraintHorizontal_weight="3" />

            <ImageView
                android:id="@+id/imgUsageStatus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_status_pending"
                android:contentDescription="סטטוס"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHelpUsage" />

            <ImageButton
                android:id="@+id/btnHelpUsage"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_help"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@color/cyan_accent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Help Guide 5 -->
        <LinearLayout
            android:id="@+id/layoutHelpUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="-10dp"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@drawable/glass_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="איך לאשר גישה לנתוני שימוש?"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <ImageView
                android:id="@+id/imgGuideUsage"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ══════════════ Step 6: Recovery Email ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step_7_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRecoveryEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="כתובת אימייל לשחזור (אופציונלי)"
            app:boxStrokeColor="@color/cyan_accent"
            app:hintTextColor="@color/cyan_accent"
            android:textColorHint="#88FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRecoveryEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Continue Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="סיום הגדרה ✓"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            app:backgroundTint="@color/purple_primary"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
