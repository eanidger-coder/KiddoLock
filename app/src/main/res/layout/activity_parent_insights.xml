<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SectionTitle"
            android:text="דוח פעילות יומית" />

        <!-- Activity Summary Card -->
        <LinearLayout
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 נתוני שימוש היום"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/tvUsageSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="מחשב נתונים"
                android:textColor="@color/white" />
        </LinearLayout>

        <!-- Insight Card 1 (Tip) -->
        <LinearLayout
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ טיפ אישי"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/tvPersonalTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="טוען טיפים"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Placeholder for more insights -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:text="תובנות נוספות יתעדכנו מחר"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
