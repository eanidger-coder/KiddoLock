<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:clipToPadding="false">

        <!-- ══════ TOP BAR: Title + Settings ══════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KiddoLock"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- ══════ PROTECTION STATUS CARD ══════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProtectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/glass_white_10"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/success_green">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgProtectionIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_secure"
                    app:tint="@color/success_green" />

                <TextView
                    android:id="@+id/tvProtectionStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/protection_active"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProtectionDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════ KIDS MODE MASTER TOGGLE ══════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKidsModeMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/glass_white_10"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1.2dp"
            app:strokeColor="@color/cyan_accent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/ivKidsModeIconMain"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_secure"
                    app:tint="@color/cyan_accent"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="מצב ילדים (ראשי)"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvKidsModeStatusMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="כל ההגנות פעילות"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnHelpKidsMode"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_help"
                    app:tint="@color/glass_white_70"
                    android:contentDescription="עזרה: מצב ילדים"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="2dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swKidsModeMain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- ══════ HEADER ══════ -->
        <TextView
            android:id="@+id/tvKidHello"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="זמן מסך"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:textAlignment="viewStart" />

        <!-- ══════ SCREEN TIME RING ══════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/time_ring_bg">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRemainingTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2:15"
                        android:textColor="@color/cyan_accent"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remaining_hours"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <!-- ══════ QUICK RESET ROW - דחה שעת שינה / אפס מונה ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnoozeBedtime"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="🌙 בטל שעת שינה הלילה"
                android:textSize="12sp"
                app:backgroundTint="#9B6EFF"
                android:textColor="@color/white"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetUsage"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="⏰ אפס שימוש היום"
                android:textSize="12sp"
                app:backgroundTint="#FFD600"
                android:textColor="#000000"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- ══════ BONUS TIME - הוסף זמן לילד ══════ -->
        <LinearLayout
            android:id="@+id/bonusTimeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:weightSum="3">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBonus10"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="+10 דקות"
                android:textSize="13sp"
                android:textColor="@color/cyan_accent"
                app:strokeColor="@color/cyan_accent"
                android:layout_marginEnd="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBonus20"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="+20 דקות"
                android:textSize="13sp"
                android:textColor="@color/cyan_accent"
                app:strokeColor="@color/cyan_accent"
                android:layout_marginHorizontal="3dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBonus30"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="+30 דקות"
                android:textSize="13sp"
                android:textColor="@color/cyan_accent"
                app:strokeColor="@color/cyan_accent"
                android:layout_marginStart="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- ══════ STATS ROW (hidden when kid mode active to declutter) ══════ -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Apps Blocked -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/GlassCard"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginEnd="6dp"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvBlockedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="@color/danger_red"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/apps_blocked"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Daily Limit -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/GlassCard"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvDailyLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4h"
                    android:textColor="@color/purple_light"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_quota"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Usage Today -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/GlassCard"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginStart="6dp"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvUsageToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1:45"
                    android:textColor="@color/success_green"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/usage_today"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════ MANAGEMENT CARDS ══════ -->
        <TextView
            style="@style/SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/management" />

        <!-- App Management Card -->
        <LinearLayout
            android:id="@+id/cardAppManagement"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_management"
                app:tint="@color/cyan_accent"
                android:background="@drawable/glass_card_bg"
                android:padding="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_management"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAppManagementSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="נהל אפליקציות, מגבלות זמן ושעות שינה"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◂"
                android:textColor="@color/text_tertiary"
                android:textSize="18sp" />
        </LinearLayout>


        <!-- ══════ ADMIN PIN (hidden - now lives in admin screen) ══════ -->
        <LinearLayout
            android:id="@+id/cardAdminPin"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🔑"
                android:textSize="24sp"
                android:background="@drawable/glass_card_bg" />

            <LinearLayout
                android:layout_