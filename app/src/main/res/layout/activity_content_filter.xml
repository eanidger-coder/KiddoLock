<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/content_filter_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/content_filter_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Enable / Disable card -->
        <androidx.cardview.widget.CardView
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/content_filter_toggle_label"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvFilterStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/content_filter_enabled"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchFilterEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Lifetime block count -->
        <TextView
            android:id="@+id/tvBlockCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Sensitivity -->
        <TextView
            style="@style/SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/content_filter_sensitivity" />

        <androidx.cardview.widget.CardView
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioGroup
                android:id="@+id/rgSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbStrict"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЧіВһЧівҖ”ЧіВһЧів„ўЧіВЁ (ЧівҖ”ЧівҖўЧіВЎЧіВқ ЧівҖҷЧіВқ ЧівҖ”ЧіВ©ЧівҖң ЧіВ§ЧіВң)"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/cyan_accent" />

                <RadioButton
                    android:id="@+id/rbBalanced"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЧіВһЧіВҗЧівҖўЧівҖ“ЧіВҹ (ЧіВһЧівҖўЧіВһЧіВңЧіВҘ)"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/cyan_accent"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbRelaxed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЧіВЎЧіВңЧівҖ”ЧіВ Чів„ў (ЧівҖ”ЧівҖўЧіВЎЧіВқ ЧіВЁЧіВ§ ЧіВһЧіВ§ЧіВЁЧів„ўЧіВқ ЧівҖҳЧіВЁЧівҖўЧіВЁЧів„ўЧіВқ)"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/cyan_accent" />
            </RadioGroup>
        </androidx.cardview.widget.CardView>

        <!-- Blacklisted channels -->
        <TextView
            style="@style/SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/content_filter_channels" />

        <androidx.cardview.widget.CardView
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etNewChannel"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="ЧіВ©ЧіВқ ЧіВўЧіВЁЧівҖўЧіВҘ ЧіВңЧівҖ”ЧіВЎЧів„ўЧіВһЧівҖқ"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:inputType="text"
                        android:maxLines="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddChannel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ЧівҖқЧівҖўЧіВЎЧіВЈ"
                        app:backgroundTint="@color/cyan_accent" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvChannelsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЧіВҗЧів„ўЧіВҹ ЧіВўЧіВЁЧівҖўЧіВҰЧів„ўЧіВқ ЧівҖ”ЧіВЎЧівҖўЧіВһЧів„ўЧіВқ"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:padding="8dp"
                    android:visibility="visible" />

                <LinearLayout
                    android:id="@+id/containerChannels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Blacklisted keywords -->
        <TextView
            style="@style/SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/content_filter_keywords" />

        <androidx.cardview.widget.CardView
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etNewKeyword"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="ЧіВһЧів„ўЧіВңЧіГ— ЧіВһЧівӮӘЧіГ—ЧівҖ” ЧіВңЧівҖ”ЧіВЎЧів„ўЧіВһЧівҖқ"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:inputType="text"
                        android:maxLines="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddKeyword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ЧівҖқЧівҖўЧіВЎЧіВЈ"
                        app:backgroundTint="@color/cyan_accent" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvKeywordsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЧіВҗЧів„ўЧіВҹ ЧіВһЧів„ўЧіВңЧівҖўЧіГ— ЧіВһЧівӮӘЧіГ—ЧівҖ” ЧіВһЧівҖўЧіГ—ЧіВҗЧіВһЧівҖўЧіГ— ЧіВҗЧів„ўЧіВ©Чів„ўЧіГ—"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:padding="8dp"
                    android:visibility="visible" />

                <LinearLayout
                    android:id="@+id/containerKeywords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>
