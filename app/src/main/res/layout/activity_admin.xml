<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark_gradient"
    android:layoutDirection="rtl">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="ניהול זמן והגדרות"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ════ Beginner Tip Card (dismissible) ════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBeginnerTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cyan_accent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="22sp"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="טיפ: ליד כל מונח טכני יש אייקון ❓ ירוק. לחץ עליו לקבלת הסבר ידידותי בעברית."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:hyphenationFrequency="none"
                        android:breakStrategy="simple" />
                    <ImageButton
                        android:id="@+id/btnDismissTip"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/glass_white_50"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="סגור טיפ" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════ QUICK ACTIONS (Change PIN / Help / How to Uninstall) ════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:weightSum="3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickChangePin"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:minHeight="52dp"
                    android:text="🔐 PIN"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginEnd="6dp"
                    app:strokeColor="#FFD600"
                    android:textColor="#FFD600"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickHelp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:minHeight="52dp"
                    android:text="❓ עזרה"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginHorizontal="6dp"
                    app:strokeColor="#9B6EFF"
                    android:textColor="#9B6EFF"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickUninstall"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:minHeight="52dp"
                    android:text="🗑️ הסרה"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginStart="6dp"
                    app:strokeColor="#FF6B6B"
                    android:textColor="#FF6B6B"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp" />
            </LinearLayout>


            <!-- Live Protection Status Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProtectionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="20dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#4CAF50"
                android:visibility="visible">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/shape_dot_green"
                        android:layout_marginEnd="12dp" />
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        
                        <TextView
                            android:id="@+id/tvProtectionStatusTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="מצב הגנה: פעיל"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:hyphenationFrequency="none"
                            android:breakStrategy="simple" />
                            
                        <TextView
                            android:id="@+id/tvProtectionStatusSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="KiddoLock שומר על המכשיר כעת"
                            android:textColor="#A0A0A0"
                            android:textSize="12sp"
                            android:hyphenationFrequency="none"
                            android:breakStrategy="simple" />
                    </LinearLayout>
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_shield"
                        app:tint="#4CAF50" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>






            <!-- AI INSIGHTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="תובנות הורים"
                    android:textColor="@color/cyan_accent"
                    android:textSize="14sp"
                    android:textAllCaps="true"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btnHelpInsights"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_help"
                    app:tint="@color/cyan_accent"
                    android:contentDescription="עזרה: תובנות הורים"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="2dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAiInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cyan_glow"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
 
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📈 צפה בדוח פעילות ותובנות הורים"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:hyphenationFrequency="none"
                        android:breakStrategy="simple" />
                        
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back"
                        android:rotation="180"
                        app:tint="@color/cyan_accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CLOUD SYNC -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
                android:visibility="gone">
    <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="גיבוי וסנכרון ענן"
                android:textColor="@color/cyan_accent"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />
    <ImageView android:id="@+id/btnHelpCloudSync"
        android:layout_width="22dp" android:layout_height="22dp"
        android:src="@drawable/ic_help" app:tint="@color/cyan_accent"
        android:contentDescription="עזרה: סנכרון ענן"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true" android:focusable="true" android:padding="2dp" />
</LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCloudSync"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cyan_accent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivSyncStatus"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_sync"
                            app:tint="@color/cyan_accent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvSyncTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="✓ סנכרון אוטומטי פעיל"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvSyncLastTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="סנכרון אחרון: מעולם לא"
                                android:textColor="@color/glass_white_50"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- APP MANAGEMENT -->
            <!-- SECURITY & PIN -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical">
    <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/security_parent_pin_title"
                android:textColor="@color/cyan_accent"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />
    <ImageView android:id="@+id/btnHelpParentPin"
        android:layout_width="22dp" android:layout_height="22dp"
        android:src="@drawable/ic_help" app:tint="@color/cyan_accent"
        android:contentDescription="עזרה: PIN הורים"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true" android:focusable="true" android:padding="2dp" />
</LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChangePin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/glass_white_20"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lock_closed"
                        app:tint="@color/cyan_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/change_pin_label"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/change_pin_desc"
                            android:textColor="@color/glass_white_50"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back"
                        android:rotation="180"
                        app:tint="@color/glass_white_50" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- HELP & ABOUT -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical">
    <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="עזרה ותמיכה"
                android:textColor="@color/cyan_accent"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />
    <ImageView android:id="@+id/btnHelpSupport"
        android:layout_width="22dp" android:layout_height="22dp"
        android:src="@drawable/ic_help" app:tint="@color/cyan_accent"
        android:contentDescription="עזרה: עזרה ותמיכה"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true" android:focusable="true" android:padding="2dp" />
</LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/glass_white_20"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_help"
                        app:tint="@color/cyan_accent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="עזרה ואודות האפליקציה"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back"
                        android:rotation="180"
                        app:tint="@color/glass_white_50" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEmergencyUninstall"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/btn_emergency_uninstall_parent"
                android:textColor="#FF5252"
                app:strokeColor="#FF5252"
                app:rippleColor="#20FF5252"
                android:textAllCaps="false"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <!-- ════ HOW TO UNINSTALL CARD - clear instructions for parents ════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/warning_amber">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❓ איך מסירים את KiddoLock? (4 שלבים)"
                        android:textColor="@color/warning_amber"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. כבה את &apos;מצב ילדים&apos; במסך הראשי של KiddoLock."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. השבת מנהל מכשיר: הגדרות → אבטחה ופרטיות → אפליקציות מנהל מכשיר → בטל את KiddoLock. (חובה - בלי זה אנדרואיד לא יאפשר הסרה)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3. הגדרות → אפליקציות → KiddoLock → הסר."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="4. אם נעלת בטעות: בהתראה למעלה לחץ &apos;❌ הסר&apos;, הזן PIN, ואז &apos;הסר עכשיו&apos; - יבצע אוטומטית את 3 השלבים."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🆘 שכחת PIN? פתח את דף השליטה מרחוק שקיבלת בדפדפן, או השתמש בקוד שחזור באימייל שהגדרת."
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="italic" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical">
    <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="ניהול אפליקציות חסומות"
                android:textColor="@color/cyan_accent"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple" />
    <ImageView android:id="@+id/btnHelpAppMgmt"
        android:layout_width="22dp" android:layout_height="22dp"
        android:src="@drawable/ic_help" app:tint="@color/cyan_accent"
        android:contentDescription="עזרה: ניהול אפליקציות"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true" android:focusable="true" android:padding="2dp" />
</LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_white_10"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- App and Time Management Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="ניהול אפליקציות וזמן"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textAlignment="viewStart"
                                android:hyphenationFrequency="none"
                                android:breakStrategy="simple" />
                            
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="אפשר או חסום אפליקציות וקבע מגבלות זמן לילד"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:textAlignment="viewStart"
                                android:hyphenationFrequency="none"
                                android:breakStrategy="simple" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal">

                                <!-- Bedtime Column -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="6dp"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnBedtime"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="שעת שינה"
                                        android:textColor="@color/white"
                                        android:textSize="12sp"
                                        app:strokeColor="@color/glass_white_20"
                                        app:icon="@drawable/ic_time"
                                        app:iconTint="@color/cyan_accent"
                                        app:cornerRadius="8dp"/>

                                    <TextView
                                        android:id="@+id/tvBedtimeValue"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="לחץ להגדרת שעות שינה (משעה - עד שעה)"
                                        android:textColor="@color/glass_white_50"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:textAlignment="center" />
                                </LinearLayout>

                                <!-- Daily Limit Column -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnDailyLimit"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="מגבלה יומית"
                                        android:textColor="@color/white"
                                        android:textSize="12sp"
                                        app:strokeColor="@color/glass_white_20"
                                        app:icon="@drawable/ic_timer"
                                        app:iconTint="@color/cyan_accent"
                                        app:cornerRadius="8dp"/>

                                    <TextView
                                        android:id="@+id/tvDailyLimitValue"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="לחץ להגדרת מגבלה יומית (דקות)"
                                        android:textColor="@color/glass_white_50"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:textAlignment="center" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@color/glass_white_10" />

                    <!-- Search and List -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="* חלק מהאפליקציות נחסמו להגנת המערכת כברירת מחדל"
                            android:textColor="@color/glass_white_50"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>

                        <EditText
                            android:id="@+id/etSearchApps"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_search_field"
                            android:drawableStart="@drawable/ic_search"
                            android:drawablePadding="12dp"
                            android:hint="חפש אפליקציה"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/glass_white_50"
                            android:textSize="14sp" />

                        <!-- Filter chips: All / Blocked / Open -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp"
                            android:gravity="center">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFilterAll"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="הכל"
                                android:textSize="13sp"
                                android:layout_marginEnd="4dp"
                                app:backgroundTint="@color/cyan_accent"
                                android:textColor="@color/bg_dark" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFilterBlocked"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="🔒 חסומות"
                                android:textSize="13sp"
                                android:layout_marginHorizontal="4dp"
                                app:strokeColor="@color/danger_red"
                                android:textColor="@color/danger_red" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFilterOpen"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="✅ פתוחות"
                                android:textSize="13sp"
                                android:layout_marginStart="4dp"
                                app:strokeColor="@color/success_green"
                                android:textColor="@color/success_green" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="500dp"
                            android:layout_marginTop="8dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvApps"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="500dp"
                                android:nestedScrollingEnabled="false"
                                android:clipToPadding="false"
                                android:overScrollMode="never"
                                android:paddingBottom="8dp" />

                            <ProgressBar
                                android:id="@+id/pbLoadingApps"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:text="גרסה 1.5.5"
                android:textColor="@color/glass_white_50"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabScrollToTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="20dp"
        android:src="@android:drawable/arrow_up_float"
        app:backgroundTint="@color/cyan_accent"
        android:contentDescription="חזור למעלה"
        android:visibility="gone"
        app:tint="@color/bg_dark" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
