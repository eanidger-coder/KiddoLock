<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:background="@drawable/glass_card_bg"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_help"
            app:tint="@color/cyan_accent"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvGuideTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_title_accessibility"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="8dp" />

        <TextView
            android:id="@+id/tvGuideDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/guide_desc_accessibility"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="8dp"
            android:clickable="true"
            android:focusable="true"
            android:hyphenationFrequency="none"
            android:breakStrategy="simple" />

        <!-- Guide Image Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGuideImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#4DFFFFFF"
            app:cardBackgroundColor="#26FFFFFF"
            android:layout_marginHorizontal="4dp"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:id="@+id/imgGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="220dp"
                android:adjustViewBounds="true"
                android:scaleType="centerInside"
                android:padding="8dp" />
                
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToSettings"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:text="@string/guide_btn_understood"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="12dp"
            app:backgroundTint="@color/purple_primary"
            app:cornerRadius="20dp"
            app:elevation="6dp" />

    </LinearLayout>
</ScrollView>
