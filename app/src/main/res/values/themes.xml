<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SafeLock" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/safelock_primary</item>
        <item name="colorSecondary">@color/safelock_secondary</item>
        <item name="colorOnPrimary">@color/safelock_on_primary</item>
        <item name="android:colorBackground">@color/safelock_background</item>
        <item name="colorSurface">@color/safelock_surface</item>
        <item name="colorError">@color/safelock_error</item>
        <item name="android:statusBarColor">@color/safelock_background</item>
        <item name="android:navigationBarColor">@color/safelock_background</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:textColorPrimary">@color/safelock_text_primary</item>
        <item name="android:textColorSecondary">@color/safelock_text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="checkboxStyle">@style/CustomCheckbox</item>
        <item name="alertDialogTheme">@style/CustomAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/CustomAlertDialog</item>
    </style>

    <!-- Backward-compat aliases so existing manifest/layouts keep working -->
    <style name="Theme.KiddoLock" parent="Theme.SafeLock" />
    <style name="Theme.SafeKids" parent="Theme.SafeLock" />

    <style name="Theme.SafeLock.Overlay" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@color/safelock_overlay_bg</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:statusBarColor">@color/safelock_background</item>
    </style>
    <style name="Theme.SafeKids.Overlay" parent="Theme.SafeLock.Overlay" />

    <style name="CustomAlertDialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@color/safelock_surface</item>
        <item name="android:textColorPrimary">@color/safelock_text_primary</item>
        <item name="android:textColorSecondary">@color/safelock_text_secondary</item>
        <item name="colorSurface">@color/safelock_surface</item>
        <item name="android:colorBackground">@color/safelock_surface</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MaterialComponents.Button.TextButton</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowMinWidthMajor">85%</item>
        <item name="android:windowMinWidthMinor">85%</item>
    </style>

    <style name="CustomCheckbox" parent="Widget.MaterialComponents.CompoundButton.CheckBox">
        <item name="buttonTint">@color/safelock_primary</item>
    </style>

    <style name="GlassCard">
        <item name="android:background">@drawable/glass_card_bg</item>
        <item name="android:padding">20dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="AccentButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/safelock_on_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/safelock_primary</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/safelock_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="StatValue">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/safelock_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="StatLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/safelock_text_secondary</item>
    </style>

    <style name="PinPadButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:background">@drawable/pin_button_bg</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">24sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:gravity">center</item>
        <item name="rippleColor">#4DFFFFFF</item>
    </style>
</resources>
